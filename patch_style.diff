/* Compound Nodes */
.pgv-compound-node {
  position: absolute;
  top: 0;
  left: 0;
  box-sizing: border-box;
  background-color: var(--pgv-color-bg-secondary);
  border: none;
  /* Use box-shadow to simulate borders so we don't mess up the inner coordinate system for absolute children */
  box-shadow:
    var(--pgv-node-shadow),
    inset 0 0 0 1px var(--pgv-node-border, #d1d5db),
    inset 5px 0 0 0 var(--pgv-node-accent);
  border-radius: var(--pgv-node-radius, 8px);
  padding: 0;
  transition: transform var(--pgv-transition-speed) ease;
  will-change: transform;
}
